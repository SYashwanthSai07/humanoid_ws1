# fast build rule for target.
ros_robot_controller_genpy/fast:
	cd /home/niat/humanoid_ws/build && $(MAKE) -f ainex_driver/ros_robot_controller/CMakeFiles/ros_robot_controller_genpy.dir/build.make ainex_driver/ros_robot_controller/CMakeFiles/ros_robot_controller_genpy.dir/build
.PHONY : ros_robot_controller_genpy/fast

